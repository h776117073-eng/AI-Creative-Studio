{
  "name": "ai-creative-studio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:services\"",
    "dev:web": "npm run dev -w @ai-creative-studio/web",
    "dev:services": "npm run dev -w @ai-creative-studio/services",
    "build": "npm run build:core && npm run build:engines && npm run build:apps",
    "build:core": "npm run build -w @ai-creative-studio/core",
    "build:engines": "npm run build -w @ai-creative-studio/creative-engine -w @ai-creative-studio/timeline-engine -w @ai-creative-studio/rendering-engine -w @ai-creative-studio/animation-engine -w @ai-creative-studio/asset-engine -w @ai-creative-studio/media-engine -w @ai-creative-studio/audio-engine -w @ai-creative-studio/image-engine -w @ai-creative-studio/video-engine -w @ai-creative-studio/effects-engine -w @ai-creative-studio/project-engine -w @ai-creative-studio/ai-engine -w @ai-creative-studio/command-engine -w @ai-creative-studio/state-engine -w @ai-creative-studio/plugin-engine -w @ai-creative-studio/export-engine -w @ai-creative-studio/template-engine -w @ai-creative-studio/collaboration-engine",
    "build:apps": "npm run build -w @ai-creative-studio/web",
    "test": "npm run test --workspaces",
    "lint": "eslint packages apps --ext .ts,.tsx",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "better-sqlite3": "^11.1.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "stripe": "^16.2.0",
    "zod": "^3.23.8"
  }
}
